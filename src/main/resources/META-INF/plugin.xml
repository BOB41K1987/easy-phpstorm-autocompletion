<idea-plugin>
    <id>com.eonx.eeh.translation-nav</id>
    <name>EasyErrorHandler Translation Navigation</name>
    <version>1.12.0</version>
    <vendor>EonX</vendor>

    <description><![CDATA[
        IDE assistance for this project's test/error conventions:
        <ul>
        <li>Autocompletion and Go to Declaration (Cmd/Ctrl+B) for EasyErrorHandler exception
        message keys, resolved live from <code>translations/messages*.php</code>
        (<code>exceptions.*</code> on a <code>BaseException</code> constructor,
        <code>user_messages.*</code> on <code>setUserMessage()</code>).</li>
        <li>Autocompletion of Zenstruck Foundry factory attribute-array keys with the
        properties of the entity the factory builds
        (e.g. <code>DisputeFactory::new()->createEntity(['&hellip;'])</code>).</li>
        </ul>
    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.jetbrains.php</depends>

    <extensions defaultExtensionNs="com.intellij">
        <gotoDeclarationHandler
            implementation="com.eonx.eeh.translationnav.ExceptionTranslationKeyGotoHandler"/>
        <gotoDeclarationHandler
            implementation="com.eonx.eeh.translationnav.ConstraintMessageGotoHandler"/>
        <completion.contributor
            language="PHP"
            implementationClass="com.eonx.eeh.translationnav.ExceptionTranslationKeyCompletionContributor"/>
        <completion.contributor
            language="PHP"
            implementationClass="com.eonx.eeh.translationnav.FactoryAttributeKeyCompletionContributor"/>
        <completion.contributor
            language="PHP"
            implementationClass="com.eonx.eeh.translationnav.EntityCriteriaKeyCompletionContributor"/>
        <completion.contributor
            language="PHP"
            implementationClass="com.eonx.eeh.translationnav.EntityCriteriaListValueCompletionContributor"/>
        <completion.contributor
            language="PHP"
            implementationClass="com.eonx.eeh.translationnav.ExceptionMessageParamsCompletionContributor"/>
        <completion.contributor
            language="PHP"
            implementationClass="com.eonx.eeh.translationnav.RepositoryCriteriaKeyCompletionContributor"/>
        <annotator
            language="PHP"
            implementationClass="com.eonx.eeh.translationnav.EntityCriteriaJsonbAnnotator"/>
        <annotator
            language="PHP"
            implementationClass="com.eonx.eeh.translationnav.ExceptionMessageParamsAnnotator"/>
    </extensions>
</idea-plugin>
